# ============================================================================
# Terraform Example Variables
# ============================================================================
# Copy this file and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# DO NOT commit terraform.tfvars to git (it may contain sensitive values).
# ============================================================================

aws_region      = "us-east-1"
project_name    = "customer-churn"
github_repo     = "VahantSharma/customer-churn-aws-ml"
deploy_endpoint = false
alert_email     = "your-email@example.com"

# Set these after bootstrapping the backend:
# terraform_state_bucket_arn = "arn:aws:s3:::customer-churn-terraform-state-ACCOUNT_ID"
# terraform_lock_table_arn   = "arn:aws:dynamodb:us-east-1:ACCOUNT_ID:table/customer-churn-terraform-locks"

# Set these after training a model:
# model_artifact_s3_uri = "s3://customer-churn-models-dev-ACCOUNT_ID/model.tar.gz"
# inference_image_uri   = "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/customer-churn-dev:latest"
